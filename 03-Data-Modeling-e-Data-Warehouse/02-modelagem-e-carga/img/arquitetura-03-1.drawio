        <mxCell id="insight-title" value="💡  Por que N₁ ≈ N₂ mas N₃ diverge?" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontFamily=Helvetica;fontColor=#D77500;" vertex="1" parent="1">
          <mxGeometry x="80" y="692" width="400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="insight-text" value="5% dos clientes TPC-H foram reclassificados sinteticamente depois de 1995 (customer_history, seed 42).&#10;• Nas modelagens A e B, o join usa o segmento ATUAL do cliente → a venda de 1995 é atribuída ao segmento de hoje.&#10;• Na modelagem C (SCD2), o join tem range temporal → a venda de 1995 é atribuída ao segmento VIGENTE naquela data." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontFamily=Helvetica;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="718" width="1030" height="60" as="geometry" />
        </mxCell>
        <mxCell id="insight-decision" value="Qual é o número certo?&#10;Depende da pergunta do negócio.&#10;&#10;Entregável do lab:&#10;DECISION.md (estilo ADR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D77500;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#D77500;arcSize=6;align=center;" vertex="1" parent="1">
